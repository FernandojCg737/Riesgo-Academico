# PostgreSQL
POSTGRES_USER=academic_user
POSTGRES_PASSWORD=academic_pass
POSTGRES_DB=academic_risk_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://academic_user:academic_pass@db:5432/academic_risk_db

# Backend
API_PORT=8000
API_HOST=0.0.0.0
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
MODEL_STORAGE_PATH=/app/models_storage
REPORTS_STORAGE_PATH=/app/reports_storage
RAW_DATA_PATH=/app/data/raw

# Constantes de dominio (override opcional; defaults viven en domain/constants.py)
UMBRAL_APROBACION=51
RANDOM_STATE=42
TEST_SIZE=0.2

# Chatbot Analítico (Módulo 5) — API key gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Key de respaldo (cuenta de Google distinta) — se usa automáticamente si la principal agota su cuota diaria
GEMINI_API_KEY_BACKUP=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
